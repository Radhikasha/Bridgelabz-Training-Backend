<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
 https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">
    <display-name>GreetingWebApp — Spring MVC</display-name>
    <!--
    ══════════════════════════════════════════════════════════════
    DispatcherServlet — The Front Controller of Spring MVC
    ══════════════════════════════════════════════════════════════
   SpringMVCImplementationPlanGreetingApplication.md 2026-06-21
   3 / 19
    This is a special servlet provided by spring-webmvc JAR.
    It intercepts ALL requests and routes them to @Controller methods.
    By convention, Spring looks for:
    /WEB-INF/<servlet-name>-servlet.xml
    Since servlet-name = "dispatcher", it loads:
    /WEB-INF/dispatcher-servlet.xml
    -->
    <servlet>
        <servlet-name>dispatcher</servlet-name>
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
        <init-param>
            <!--
            Optionally specify the location of the Spring MVC config file.
            If omitted, Spring defaults to /WEB-INF/dispatcher-servlet.xml
            -->
            <param-name>contextConfigLocation</param-name>
            <param-value>WEB-INF/dispatcher-servlet.xml</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
        <!--
        load-on-startup=1: DispatcherServlet initializes at Tomcat startup,
        which also triggers Spring context initialization — loading all beans.
        -->
    </servlet>
    <!--
    ══════════════════════════════════════════════════════════════
    Servlet Mapping — Route ALL requests to DispatcherServlet
    ══════════════════════════════════════════════════════════════
    "/" means: handle all URLs not matched by other servlets.
    This makes DispatcherServlet the front controller for the entire app.
    "/*" would be too greedy — it intercepts JSP renders too (avoid this).
    "/" is the correct pattern for Spring MVC.
    -->
    <servlet-mapping>
        <servlet-name>dispatcher</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>
    <!--
    ══════════════════════════════════════════════════════════════
    Welcome File
    ══════════════════════════════════════════════════════════════
    -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>